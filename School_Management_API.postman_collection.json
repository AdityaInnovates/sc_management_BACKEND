    {
      "name": "List Schools",
      "description": "Retrieves all schools from the database, sorted by their geographical proximity to the provided coordinates.",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/listSchools?latitude=12.9100&longitude=77.6700",
          "host": ["{{base_url}}"],
          "path": ["listSchools"],
          "query": [
            {
              "key": "latitude",
              "value": "12.9100",
              "description": "User's current latitude (-90 to 90)"
            },
            {
              "key": "longitude",
              "value": "77.6700",
              "description": "User's current longitude (-180 to 180)"
            }
          ]
        },
        "description": "Uses the Haversine formula (or similar) to calculate distance in kilometers and sorts results ascending."
      },
